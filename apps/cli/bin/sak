#!/bin/bash
set -euo pipefail

# bin/sak is installed as a symlink (~/.local/bin/sak -> ~/.sak/bin/sak);
# BASH_SOURCE doesn't follow symlinks, so resolve the chain manually before
# deriving SAK_HOME from our own location.
SAK_SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SAK_SOURCE" ]; do
  SAK_SOURCE_DIR="$(cd -P "$(dirname "$SAK_SOURCE")" && pwd)"
  SAK_SOURCE="$(readlink "$SAK_SOURCE")"
  [[ "$SAK_SOURCE" != /* ]] && SAK_SOURCE="$SAK_SOURCE_DIR/$SAK_SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SAK_SOURCE")" && pwd)"
SAK_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"
SAK_LATEST_RELEASE_API="https://api.github.com/repos/coodyapp/sak/releases/latest"
SAK_VERSION="0.2.1"

# shellcheck source=apps/cli/lib/os.sh
source "$SAK_HOME/lib/os.sh"
# shellcheck source=apps/cli/lib/colors.sh
source "$SAK_HOME/lib/colors.sh"
# shellcheck source=apps/cli/lib/banner.sh
source "$SAK_HOME/lib/banner.sh"

usage() {
  cat <<EOF
A Swiss Army Knife that Install the tools you actually use with a single command.

Usage:
  sak list              List available tools
  sak install <tool>    Install a tool
  sak update            Update SAK to the latest version
  sak version           Show version
  sak help              Show this help

Ops (one-shot maintenance tasks against a provider's API/CLI):
  sak cloudflare <action>   dns, ip, tunnels, mtls, worker-purge
  sak gh <action>           prs, purge-artifacts
EOF
}

list_tools() {
  local dir
  for dir in "$SAK_HOME"/src/*/; do
    [[ -f "$dir/setup.sh" ]] && basename "$dir"
  done
}

_installed_version() {
  local bin="$1"
  command -v "$bin" >/dev/null 2>&1 || { echo "not installed"; return; }
  local raw
  raw="$("$bin" --version 2>/dev/null || true)"
  echo "$raw" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1
}

cmd_list() {
  echo "Available tools:"
  local tool meta
  for tool in $(list_tools); do
    meta="$SAK_HOME/src/$tool/meta.sh"
    if [[ -f "$meta" ]]; then
      (
        # shellcheck source=/dev/null
        source "$meta"
        version="$(_installed_version "${TOOL_BIN:-$tool}")"
        echo "  - ${TOOL_NAME:-$tool}: ${version:-unknown} - ${TOOL_DESCRIPTION:-}"
      )
    else
      echo "  - $tool"
    fi
  done
}

cmd_install() {
  local tool="${1:?Usage: sak install <tool>}"
  local script="$SAK_HOME/src/$tool/setup.sh"
  [[ -f "$script" ]] || { echo "Unknown tool: $tool" >&2; cmd_list; exit 1; }
  require_debian_based

  local meta="$SAK_HOME/src/$tool/meta.sh"
  local tool_name="$tool"
  [[ -f "$meta" ]] && tool_name="$(source "$meta"; echo "${TOOL_NAME:-$tool}")"

  local reply
  read -r -p "Install $tool_name? [y/N] " reply
  case "$reply" in
    [yY]|[yY][eE][sS]) ;;
    *) echo "Aborted." >&2; exit 1 ;;
  esac

  bash "$script"
}

cmd_update() {
  echo "Updating SAK..."
  local tag tarball tmp new_home
  tag="$(curl -fsSL "$SAK_LATEST_RELEASE_API" | grep -m1 '"tag_name"' | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')"
  [[ -n "$tag" ]] || { echo "Could not determine the latest SAK release." >&2; exit 1; }
  tarball="https://github.com/coodyapp/sak/archive/refs/tags/$tag.tar.gz"
  tmp="$(mktemp -d)"
  curl -fsSL "$tarball" | tar -xz -C "$tmp" --strip-components=1
  # Stage into a fresh directory and swap it in, rather than cp -a'ing onto
  # $SAK_HOME in place: this script is itself $SAK_HOME/bin/sak, and
  # overwriting a file mid-execution desyncs bash's read offset. rm+mv only
  # unlinks/replaces the directory entry, so our already-open fd keeps
  # reading the original content safely to the end.
  new_home="$(mktemp -d)"
  cp -a "$tmp/apps/cli/." "$new_home/"
  rm -rf "$tmp"
  rm -rf "$SAK_HOME"
  mv "$new_home" "$SAK_HOME"
  echo "SAK updated to $tag."
}

list_ops() {
  local namespace="$1" f
  for f in "$SAK_HOME"/ops/"$namespace"/*.sh; do
    [[ -f "$f" ]] && basename "$f" .sh
  done
}

cmd_ops() {
  local namespace="$1"; shift
  local action="${1:-}"
  if [[ -z "$action" || ! -f "$SAK_HOME/ops/$namespace/$action.sh" ]]; then
    if [[ -n "$action" ]]; then
      echo "Unknown $namespace action: $action" >&2
    else
      echo "Usage: sak $namespace <action> [args...]" >&2
    fi
    echo >&2
    echo "Available actions:" >&2
    list_ops "$namespace" | sed 's/^/  - /' >&2
    exit 1
  fi
  shift
  bash "$SAK_HOME/ops/$namespace/$action.sh" "$@"
}

case "${1:-}" in
  "") render_banner "$SAK_VERSION" ;;
  list) cmd_list ;;
  install) shift; cmd_install "${1:-}" ;;
  update) cmd_update ;;
  version) echo "SAK $SAK_VERSION" ;;
  cloudflare) shift; cmd_ops cloudflare "$@" ;;
  gh) shift; cmd_ops gh "$@" ;;
  help|--help|-h) usage ;;
  *) echo "Unknown command: $1" >&2; usage; exit 1 ;;
esac
